# Copy to `.env` for tooling that reads dotenv (drizzle-kit). For Cloudflare
# Workers runtime, use `.dev.vars` inside apps/api instead — neither file is
# committed (see .gitignore).
#
# Inside the dev container the compose file already injects these; this file
# is for host-side tooling (drizzle studio, psql, etc.).

# Postgres reachable from the host via the published port (54322).
# Inside the dev container itself it's postgres://synapse:synapse@postgres:5432/synapse_dev.
DATABASE_URL=postgres://synapse:synapse@127.0.0.1:54322/synapse_dev

# Better-Auth — replace BETTER_AUTH_SECRET with a real secret per environment.
BETTER_AUTH_URL=http://localhost:8787
BETTER_AUTH_SECRET=dev-only-not-a-real-secret-change-me

# Origin of the web client (CORS allow-list).
WEB_ORIGIN=http://localhost:5173

# Web app — override API URL if pointing at a deployed worker.
VITE_API_URL=http://localhost:8787
