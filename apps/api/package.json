{
  "name": "@synapse/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SYNAPSE API (Hono on Cloudflare Workers + tRPC v11).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "scripts": {
    "dev": "wrangler dev --ip 0.0.0.0",
    "build": "tsc -b",
    "deploy": "wrangler deploy",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo .wrangler"
  },
  "dependencies": {
    "@synapse/blocks": "workspace:*",
    "@synapse/schema": "workspace:*",
    "@trpc/server": "^11.0.0-rc.617",
    "better-auth": "^1.1.2",
    "drizzle-orm": "^0.36.4",
    "hono": "^4.6.10",
    "pg": "^8.13.1",
    "superjson": "^2.2.1",
    "ulid": "^2.3.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241112.0",
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "^3.87.0"
  }
}
