    "ag-grid-react": "^32.3.3",
    "hyperformula": "^2.7.1",
    "@tiptap/core": "^2.10.3",
    "@tiptap/extension-collaboration": "^2.10.3",
    "@tiptap/extension-placeholder": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
