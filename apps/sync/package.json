{
  "name": "@synapse/sync",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "SYNAPSE realtime sync (Hocuspocus / Yjs websocket server). Runs as a long-lived container.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b",
    "start": "node dist/index.js",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@hocuspocus/extension-database": "^2.15.2",
    "@hocuspocus/server": "^2.15.2",
    "@synapse/blocks": "workspace:*",
    "@synapse/schema": "workspace:*",
    "drizzle-orm": "^0.36.4",
    "pg": "^8.13.1",
    "y-prosemirror": "^1.3.4",
    "yjs": "^13.6.20"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
