{
  "$schema": "https://raw.githubusercontent.com/devcontainers/spec/main/schemas/devContainer.schema.json",
  "name": "SYNAPSE Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "dev",
  "workspaceFolder": "/workspace",

  // Run `pnpm install` automatically on first create. After that the named
  // volume keeps node_modules around so subsequent rebuilds are fast.
  "postCreateCommand": ".devcontainer/post-create.sh",

  // Ports VS Code / Cursor will surface in the Ports panel.
  "forwardPorts": [5173, 8787, 1234, 1235, 54322],
  "portsAttributes": {
    "5173": { "label": "web (vite)", "onAutoForward": "notify" },
    "8787": { "label": "api (wrangler)", "onAutoForward": "notify" },
    "1234": { "label": "sync (hocuspocus)", "onAutoForward": "silent" },
    "1235": { "label": "sync internal doc-write (loopback)", "onAutoForward": "silent" },
    "54322": { "label": "postgres", "onAutoForward": "silent" }
  },

  "remoteUser": "node",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "eslint.useFlatConfig": true,
        "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "[typescriptreact]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
        "typescript.tsdk": "node_modules/typescript/lib"
      }
    }
  },

  // Keep volumes and the project isolated from any other compose project on
  // the same Docker daemon.
  "shutdownAction": "stopCompose"
}
