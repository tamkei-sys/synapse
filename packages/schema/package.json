{
  "name": "@synapse/schema",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared Zod + Drizzle schema. Source of truth for cross-app types.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models.d.ts",
      "import": "./dist/models.js"
    },
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "test": "vitest run",
    "db:generate": "tsc -b && drizzle-kit generate",
    "db:migrate": "tsc -b && drizzle-kit migrate",
    "db:studio": "tsc -b && drizzle-kit studio",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "drizzle-zod": "^0.5.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
